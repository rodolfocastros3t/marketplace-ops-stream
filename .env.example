# Copie para .env e ajuste se necessário (nunca commite o .env)

# Modo kafka | embedded
PIPELINE_MODE=embedded

# Com Docker Compose (rede interna):
# KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
# PIPELINE_MODE=kafka

# Local apontando para Redpanda exposto:
# KAFKA_BOOTSTRAP_SERVERS=localhost:19092
# PIPELINE_MODE=kafka
