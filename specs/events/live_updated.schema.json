{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vitrine.local/schemas/live_updated.schema.json",
  "title": "LiveUpdated",
  "type": "object",
  "required": ["event", "ts", "payload"],
  "properties": {
    "event": { "const": "live.updated" },
    "ts": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "required": ["id", "titulo", "status", "espectadores", "vendedor_uf"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "titulo": { "type": "string" },
        "status": { "type": "string", "enum": ["AGENDADA", "AO_VIVO", "ENCERRADA"] },
        "espectadores": { "type": "integer", "minimum": 0 },
        "vendedor_uf": { "type": "string", "minLength": 2, "maxLength": 2 },
        "pedidos_na_live": { "type": "integer", "minimum": 0 },
        "gmv_live_centavos": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
