{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vitrine.local/schemas/envelope.schema.json",
  "title": "StreamEnvelope",
  "type": "object",
  "required": ["event", "ts", "payload"],
  "additionalProperties": false,
  "properties": {
    "event": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    }
  }
}
